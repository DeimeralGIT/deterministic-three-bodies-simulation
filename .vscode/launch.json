{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open Deployed Build (Local)",
      "type": "pwa-chrome",
      "request": "launch",
      "file": "${workspaceFolder}/public/index.html",
      "webRoot": "${workspaceFolder}/public"
    },
    {
      "name": "Run Three-Body Simulation (Python)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/simulation.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
